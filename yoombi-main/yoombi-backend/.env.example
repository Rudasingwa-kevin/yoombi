# ─────────────────────────────────────────────────────────────────────────────
# Yoombi Backend — Environment Variables
# 
# 1. Copy this file: cp .env.example .env
# 2. Fill in ALL required values before starting the server.
# 3. Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ─── DATABASE ────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Example (local):      postgresql://postgres:password@localhost:5432/yoombi
# Example (Railway):    postgresql://postgres:xxx@xxx.railway.app:5432/railway

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/yoombi


# ─── JWT / AUTH ───────────────────────────────────────────────────────────────
# REQUIRED. Must be a long, random string — minimum 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# The server will REFUSE to start if this is missing.

JWT_SECRET=CHANGE_ME_generate_a_strong_random_secret_here


# ─── SERVER ───────────────────────────────────────────────────────────────────
# The port the Express server listens on. Defaults to 3000 if not set.

PORT=3000


# ─── CLOUDINARY (Image Uploads) ───────────────────────────────────────────────
# Required for restaurant image uploads and story media.
# Get credentials at: https://cloudinary.com/console

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret


# ─── SENDGRID (Transactional Email) ───────────────────────────────────────────
# Required for password reset emails and email verification.
# Get an API key at: https://app.sendgrid.com/settings/api_keys
# Make sure the FROM_EMAIL is a verified sender in your SendGrid account.

SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yoombi.com


# ─── FRONTEND URL ─────────────────────────────────────────────────────────────
# Base URL of the frontend app (used in password-reset email links).
# For local Expo dev: http://localhost:19006
# For production:     https://app.yoombi.rw

FRONTEND_URL=http://localhost:19006
